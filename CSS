body {
  margin: 0;
  padding: 0;
  background-color: #fcedc0;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  height: -webkit-fill-available;
  overflow: hidden;
  font-family: 'M PLUS Rounded 1c', sans-serif;
  touch-action: none;
  user-select: none;
  color: #331a00;
  transition: background 0.3s;
  box-sizing: border-box;
}

/* 画面サイズいっぱいに広げるが、中身は絶対はみ出させない */
.screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100vw;
  height: 100vh;
  height: -webkit-fill-available;
  padding: 15px;
  box-sizing: border-box;
  overflow: hidden;
}

.hidden {
  display: none !important;
}

/* ★タイトル画面が上にいきすぎるのを防ぐラッパー設定 */
#menu-wrapper, #settings-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transform-origin: center center;
  max-width: 100%;
  max-height: 95vh;
}

/* ロゴのサイズと位置をさらに適正化 */
.cute-title-logo {
  font-size: 32px;
  font-weight: 900;
  margin-bottom: 35px;
  margin-top: 10px; /* 上にいきすぎないようマージン追加 */
  letter-spacing: 1px;
  filter: drop-shadow(0 4px 0 #331a00);
  display: flex;
  gap: 3px;
  justify-content: center;
}
.cute-title-logo span {
  display: inline-block;
  padding: 4px 8px;
  border: 3px solid #331a00;
  border-radius: 12px;
  background: #fff;
}
.char-i   { color: #ff4a6b; background: #fff0f2 !important; transform: rotate(-8deg) translateY(-3px) !important; }
.char-n   { color: #ff7729; background: #fff3eb !important; transform: rotate(5deg) translateY(2px) !important; }
.char-ku  { color: #a352ff; background: #f6e6ff !important; transform: rotate(-4deg) !important; }
.char-ge  { color: #24b33b; background: #ebfbeb !important; transform: rotate(6deg) translateY(-2px) !important; }
.char-mu  { color: #3377ff; background: #ebf2ff !important; transform: rotate(-6deg) !important; }
.char-mu2 { color: #ffa629; background: #fff8eb !important; transform: rotate(4deg) translateY(3px) !important; }

.menu-buttons {
  display: flex;
  flex-direction: column;
  gap: 15px;
  width: 200px;
}
button {
  font-family: 'M PLUS Rounded 1c', sans-serif;
  font-weight: 800;
  font-size: 17px;
  padding: 12px;
  border: 3px solid #e0a96d;
  border-radius: 12px;
  background-color: #fffdf6;
  color: #331a00;
  cursor: pointer;
  box-shadow: 0 5px 0 #c2935c;
  transition: transform 0.1s;
}
button:active {
  transform: translateY(5px);
  box-shadow: none;
}

#settings-screen h2 {
  margin-bottom: 20px;
  color: #8c6239;
}
.setting-item {
  background: #fffdf6;
  border: 3px solid #e0a96d;
  border-radius: 8px;
  padding: 15px;
  margin-bottom: 20px;
  display: flex;
  gap: 10px;
  align-items: center;
}
select {
  font-family: 'M PLUS Rounded 1c', sans-serif;
  font-size: 14px;
  padding: 5px;
  border: 2px solid #e0a96d;
  border-radius: 4px;
}

/* ★ゲーム画面全体ラッパー：絶対にはみ出さないよう最大高さを指定 */
#wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 352px; 
  max-height: 96vh; /* 二重のセーフティ：これ以上絶対に縦に広がらない */
  box-sizing: border-box;
  transform-origin: center center; 
  backface-visibility: hidden;
}
.cpu-mode-active #wrapper {
  width: 714px;
}

#info-panel {
  display: flex;
  justify-content: space-between;
  width: 340px;
  gap: 8px;
  box-sizing: border-box;
}
.cpu-mode-active #info-panel {
  width: 690px;
}
.info-box {
  background: #fffdf6;
  border: 3px solid #e0a96d;
  border-radius: 8px;
  padding: 4px 12px;
  text-align: center;
  font-size: 11px;
  box-shadow: 0 4px 6px rgba(0,0,0,0.05);
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.next-box { flex: 0 0 75px; }
#score-val, #cpu-score-val { font-size: 18px; color: #ff4a6b; font-weight: 900; }
#nextCanvas { width: 32px; height: 32px; }

#games-layout {
  display: flex;
  gap: 10px;
  justify-content: center;
  align-items: center;
}

.matter-container {
  border: 6px solid #e0a96d;
  border-radius: 12px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  position: relative;
  background-color: #fffdf6; 
  width: 340px;
  height: 520px;
  overflow: hidden;
  box-sizing: border-box;
}
.matter-container canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100% !important;
  height: 100% !important;
  display: block;
}

#evolution-guide {
  width: 340px;
  background: #fffdf6;
  border: 3px solid #e0a96d;
  border-radius: 8px;
  padding: 6px;
  box-sizing: border-box;
  text-align: center;
}
.cpu-mode-active #evolution-guide {
  width: 690px;
}
.guide-title { font-size: 10px; margin-bottom: 2px; color: #8c6239; font-weight: 800; }
#gauge-dots { display: flex; justify-content: center; align-items: center; gap: 4px; flex-wrap: wrap; }
.gauge-dot { border-radius: 50%; border: 2px solid #331a00; }
#to-menu-btn { font-size: 13px; padding: 6px 16px; margin-top: 0px; box-shadow: 0 3px 0 #c2935c;}
